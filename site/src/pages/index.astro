---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import ExplorerHero from "../components/ExplorerHero.astro";
import ProtocolStrip from "../components/ProtocolStrip.astro";
import FeatureCard from "../components/FeatureCard.astro";

const features = [
  {
    title: "Dual-pane UI",
    body: "Browse local and remote file systems from a terminal interface.",
  },
  { title: "Cross platform", body: "Runs on Windows, macOS, Linux and BSD." },
  {
    title: "Configurable",
    body: "Customize the explorer, the text editor and default options.",
  },
  {
    title: "Bookmarks",
    body: "Connect to favourite hosts via bookmarks and recent connections.",
  },
  {
    title: "Credential storage",
    body: "Store passwords in your operating system key vault.",
  },
  {
    title: "Rust runtime",
    body: "Built in Rust for predictable performance and portable releases.",
  },
];
---

<Base
  title="EasySCP — terminal SCP/SFTP/FTP/SMB file transfer client"
  description="Terminal file transfer client and dual-pane file manager for SCP, SFTP, FTP, SMB, S3, WebDAV and Kubernetes."
  path="/"
>
  <Nav />
  <main class="flex-1">
    <ExplorerHero />
    <section class="mx-auto max-w-5xl px-4 py-12">
      <h2 class="mb-6 text-center text-xl text-text">Why easyscp</h2>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((f) => <FeatureCard title={f.title} body={f.body} />)}
      </div>
    </section>
    <ProtocolStrip />
  </main>
  <Footer />
</Base>
